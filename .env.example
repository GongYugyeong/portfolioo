# 환경 변수 스키마 (실제 값은 .env.local 또는 GitHub Actions workflow에서 주입)
#
# 로컬 개발: 이 파일을 .env.local로 복사 후 값 채우기
#   cp .env.example .env.local
#
# 프로덕션 빌드 (GitHub Pages): .github/workflows/deploy.yml 의 env: 블록에서 주입
#
# 주의: NEXT_PUBLIC_* 접두사가 붙은 변수는 클라이언트 번들에 그대로 포함됩니다.
#      절대 시크릿(API 키, DB 패스워드 등)을 NEXT_PUBLIC_*로 노출하지 마세요.

# 로그/디버깅 게이트  ('local' | 'development' | 'production')
NEXT_PUBLIC_ENV=local

# 외부 API URL (현재 미사용, 추후 백엔드 연결 시 사용)
NEXT_PUBLIC_API_URL=

# axios baseURL — 개발환경 전용 fallback
# (운영환경에서는 코드에서 '/api' 고정)
NEXT_PUBLIC_BASE_URL=http://localhost:3000/api
